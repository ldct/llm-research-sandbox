---
const cards = [
  { title: 'Astro', tag: 'SSG' },
  { title: 'SwiftUI', tag: 'iOS' },
  { title: 'Compose', tag: 'Android' },
  { title: 'Flutter', tag: 'cross-platform' },
  { title: 'Flexbox', tag: 'CSS' },
  { title: 'Grid', tag: 'CSS' },
  { title: 'UIKit', tag: 'iOS' },
  { title: 'Qt', tag: 'desktop' },
];
---
<div class="grid">
  {cards.map((c) => (
    <div class="card">
      <div class="title">{c.title}</div>
      <div class="tag">{c.tag}</div>
    </div>
  ))}
</div>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 12px;
    padding: 8px;
    border: 1px dashed #afb8c1;
    border-radius: 6px;
    background: #f6f8fa;
  }
  .card {
    background: white;
    padding: 14px;
    border: 1px solid #d0d7de;
    border-radius: 4px;
  }
  .title { font-family: var(--mono); font-weight: 600; color: #1f2328; }
  .tag { font-family: var(--mono); font-size: 0.75rem; color: #6e7781; }
</style>
